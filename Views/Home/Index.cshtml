@model ContactViewModel
@{
    ViewData["Title"] = "Samarth Loni";
}

<section class="hero">
    <div class="container">

        <div class="row align-items-center min-vh-100">

            <div class="col-lg-7">

                <h1 class="display-2 fw-bold">
                    Hi, I'm
                    <span class="gradient-text">
                        Samarth Loni
                    </span>
                </h1>

                <h2 class="typing-text mt-3">
                    Full Stack .NET Developer
                </h2>

                <p class="lead mt-4">
                    Building scalable Web APIs, enterprise applications,
                    and mobile apps using ASP.NET Core, Angular,
                    SQL Server, and MAUI.
                </p>

                <div class="mt-4 d-flex flex-wrap gap-3 justify-content-center justify-content-lg-start">

                    <a href="#contact"
                       class="btn btn-primary btn-lg me-3">
                        Hire Me
                    </a>

                    <a href="#projects"
                       class="btn btn-outline-light btn-lg">
                        View Projects
                    </a>
                    <a class="btn btn-success btn-lg"
                       href="/resume/Samarth_Loni.pdf">

                        Download Resume
                    </a>

                </div>

                <div class="stats mt-5">

                    <div>
                        <h3>4+</h3>
                        <p>Years Experience</p>
                    </div>

                    <div>
                        <h3>20+</h3>
                        <p>Projects</p>
                    </div>

                    <div>
                        <h3>100%</h3>
                        <p>Client Focus</p>
                    </div>

                </div>

            </div>

            <div class="col-lg-5 text-center">

                <img src="/images/samarth.png"
                     class="profile-img"
                     alt="Samarth" />

            </div>

        </div>

    </div>
</section>

<section id="about" class="section-dark">
    <div class="container">

        <h2 class="section-title">About Me</h2>

        <p class="about-text">
            Experienced ASP.NET Core Developer with 4+ years of
            experience developing secure Web APIs, MVC applications,
            mobile applications, and enterprise solutions.
        </p>

    </div>
</section>

<section id="skills" class="section-dark">
    <div class="container">

        <h2 class="section-title">Skills</h2>

        <div class="skill-tags">

            <span>C#</span>
            <span>ASP.NET Core</span>
            <span>Web API</span>
            <span>Entity Framework</span>
            <span>SQL Server</span>
            <span>Angular</span>
            <span>Azure</span>
            <span>JWT</span>
            <span>MAUI</span>
            <span>Xamarin</span>

        </div>

    </div>
</section>

<section id="projects" class="section-dark">
    <div class="container">

        <h2 class="section-title">Featured Projects</h2>

        <div class="row">

            <div class="col-md-6 mb-4">

                <div class="project-card">

                    <h3>Loan Management Platform</h3>

                    <p>
                        Secure loan servicing platform with JWT,
                        payment processing, ACH integration,
                        and REST APIs.
                    </p>

                </div>

            </div>

            <div class="col-md-6 mb-4">

                <div class="project-card">

                    <h3>Book Store Application</h3>

                    <p>
                        MVC application with authentication,
                        shopping cart, orders,
                        and admin dashboard.
                    </p>

                </div>

            </div>

        </div>

    </div>
</section>

<section id="contact" class="section-dark">
    <div class="container text-center">

        <h2 class="section-title">
            Let's Build Something Great Together
        </h2>

        <p>
            Email: samarthloni1111@gmail.com
        </p>

        <a asp-controller="Contact"
           asp-action="Contact"
           class="btn btn-primary">
            Contact Me
        </a>

    </div>
</section>